// command palette (cmd-shift-p / ctrl-shift-p)
{
  "terminal": {
    "font_size": 14.0,
    "font_family": "JetBrainsMono Nerd Font"
  },
  "relative_line_numbers": "enabled",
  "gutter": {
    "line_numbers": true
  },
  "minimap": {
    "show": "never"
  },
  "buffer_font_fallbacks": [
    "Droid Sans Mono",
    "monospace",
    "monospace"
  ],
  "base_keymap": "VSCode",
  "git_panel": {
    "tree_view": true
  },
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^which\\s+pdftotext(\\s|$)",
            },
          ],
        },
      },
    },
    "default_model": {
      "effort": "high",
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
  },
  "cursor_blink": true,
  "buffer_line_height": "standard",
  "buffer_font_weight": 400.0,
  // "buffer_font_family": ".ZedMono",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "icon_theme": "Catppuccin Macchiato",
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "ui_font_size": 13.0,
  "buffer_font_size": 15.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "project_panel": {
    "entry_spacing": "standard",
  },
  "tabs": {
    "file_icons": true,
  },
}
